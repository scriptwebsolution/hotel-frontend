# Server
NODE_ENV=development
PORT=5000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=YOUR_PASSWORD
DB_NAME=hotel_db

# Auth
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# Google OAuth (Web client ID from Google Cloud Console)
GOOGLE_CLIENT_ID=

# CORS
CORS_ORIGIN=http://localhost:5173
